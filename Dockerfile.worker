# worker 컨테이너 — node-cron 잡 엔트리포인트(alarm/weather/proactive/memory/handoff/backup).
# app과 같은 코드베이스(src/db, src/lib 공유), 다른 엔트리포인트.
FROM node:22-alpine
# libc6-compat: 일부 네이티브 모듈용. postgresql16-client: backupJob 의 pg_dump(서버 pg16과 동일 버전).
RUN apk add --no-cache libc6-compat postgresql16-client
WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm install
COPY . .
CMD ["npx", "tsx", "worker/index.ts"]
