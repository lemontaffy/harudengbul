# 하루등불 환경변수. 서버에 .env로 복사해 채운다 (.env는 git에 올리지 않음).

# --- 앱 / 도메인 ---
DOMAIN=daltavern.org
APP_ORIGIN=https://haru.daltavern.org

# --- DB (docker 내부망. host 노출 안 함) ---
# ⚠️ POSTGRES_PASSWORD 는 영숫자만 권장(특수문자 X). DB_URL 안의 비밀번호와 반드시 동일.
# ⚠️ 비밀번호는 ./data/pg 가 "처음 생성될 때"만 적용됨. 나중에 바꾸려면 볼륨 삭제 필요:
#     docker compose down && sudo rm -rf ./data/pg && docker compose up -d --build
POSTGRES_USER=haru
POSTGRES_PASSWORD=change_me_strong
POSTGRES_DB=haru
DB_URL=postgres://haru:change_me_strong@db:5432/haru

# --- AI 연결 (사용자별) ---
# 채팅 연결은 사용자별로 /settings 에서 각자 입력(OpenAI 호환: 키 + Base URL + 모델).
# 아래 LLM_* 는 선택 — 설정 시 첫 admin "본인 연결"만 부트스트랩 시드(전역 공유 아님).
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# --- 인증 / 세션 (DELTA: 초대제 멀티유저) ---
# 첫 admin 부트스트랩용. 사용자가 0명일 때 ADMIN_USERNAME + APP_PASSWORD_HASH로 관리자 1명 생성.
# 해시 생성: docker compose run --rm worker npm run hash-password -- '관리자비밀번호'
# ⚠️ argon2 해시는 $ 를 포함하므로 반드시 작은따옴표로 감쌀 것 (안 그러면 compose가 $argon2id 등을 변수로 해석):
#     APP_PASSWORD_HASH='$argon2id$v=19$m=19456,t=2,p=1$...$...'
ADMIN_USERNAME=admin
APP_PASSWORD_HASH=
# openssl rand -base64 32
SESSION_SECRET=

# --- 비밀값 암호화 (llm_api_key 등) ---
# DB에 저장되는 API 키를 AES-256-GCM으로 암호화하는 키. base64 32바이트.
#   생성: openssl rand -base64 32
# 비워두면 SESSION_SECRET 에서 파생(HKDF). 단, 전용 키를 두면 SESSION_SECRET 교체와 분리 가능.
# ⚠️ 키를 바꾸면 기존 암호화된 키는 복호화 불가 → 사용자가 키를 재입력해야 함.
APP_ENCRYPTION_KEY=

# --- 아바타 저장소 ---
# 캐릭터 아바타 파일 디렉터리. docker compose 가 /data/avatars 로 주입(볼륨 ./data/avatars).
# 로컬 개발(npm run dev)에선 비워두면 프로젝트의 ./data/avatars 를 사용.
AVATARS_DIR=/data/avatars

# --- 웹푸시 (VAPID) ---
# 키 생성: npm run vapid-keys  (또는 npx web-push generate-vapid-keys)
#   출력의 Public/Private 를 아래에 붙여넣는다. 한 번 정하면 바꾸지 말 것(기존 구독 무효화).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# 발송자 식별 — mailto: 또는 https URL. 비우면 APP_ORIGIN 사용.
VAPID_SUBJECT=

# --- 날씨 (KMA 우선, OWM 폴백) ---
# 기상청 단기예보: data.go.kr 의 "일반 인증키(Decoding)" 를 넣는다.
KMA_API_KEY=
# OpenWeatherMap (KMA 실패/미설정 시 폴백). 둘 다 비우면 날씨 슬롯은 비활성.
OWM_API_KEY=

# --- Google 캘린더 연동 (OAuth) ---
# Google Cloud 콘솔에서 OAuth 클라이언트(웹) 생성. docs/GOOGLE.md 참고.
# 승인된 리다이렉트 URI: {APP_ORIGIN}/api/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- 백업 (worker backupJob, 매일 04:00 pg_dump → 7일 로테이션) ---
# docker compose 가 /data/backups 로 주입(볼륨 ./data/backups). 비우면 /data/backups.
BACKUP_DIR=/data/backups
BACKUP_KEEP=7

# --- TWA(안드로이드 APK) — /.well-known/assetlinks.json 서빙용 ---
# Bubblewrap 으로 앱/키스토어 생성 후 채운다. docs/TWA.md 참고.
TWA_PACKAGE_NAME=org.daltavern.haru
# 키스토어 SHA-256 지문(쉼표로 여러 개: 업로드키/Play 서명키 등). 비우면 검증 통과 안 됨.
ASSETLINKS_FINGERPRINTS=
