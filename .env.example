# 하루등불 환경변수. 서버에 .env로 복사해 채운다 (.env는 git에 올리지 않음).

# --- 앱 / 도메인 ---
DOMAIN=daltavern.org
APP_ORIGIN=https://haru.daltavern.org

# --- DB (docker 내부망. host 노출 안 함) ---
POSTGRES_USER=haru
POSTGRES_PASSWORD=change_me_strong
POSTGRES_DB=haru
DB_URL=postgres://haru:change_me_strong@db:5432/haru

# --- AI (OpenRouter) ---
OPENROUTER_API_KEY=
# 언제든 교체 가능. 코드는 이 값만 참조(모델명 하드코딩 금지).
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# --- 인증 / 세션 ---
# APP_PASSWORD를 argon2 해시로 변환해 넣는다: npm run hash-password -- '내비밀번호'
APP_PASSWORD_HASH=
# openssl rand -base64 32
SESSION_SECRET=

# --- Phase 2 이후 (지금은 비워둬도 됨) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
KMA_API_KEY=
